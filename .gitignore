# Runtime / generated
runs/
logs/
state/
*.pyc
__pycache__/
.DS_Store

# Environment & local config
.env
.env.*
config/*.local.*
# Local Claude Code settings can accumulate secrets via approved commands
# (seen live: admin basic-auth password in an allowlisted curl, audit OP3).
# The global ~/.config/git/ignore also covers it, but that protection does
# not travel with the repo — this line does.
.claude/settings.local.json

# Secrets / credentials — never commit (see docs/AUDIT.md S1)
# Specific patterns only, so source files are never accidentally ignored.
*.pem
*.key
*.crt
*.p12
*.pfx
auth.txt
secrets.json
*.secret
*.token

# Cookies / sessions / 2FA / network captures
cookies.txt
cookies.json
*.cookies
*.har
*.otp
